# Coupang Partners API Keys
COUPANG_PARTNERS_ACCESS_KEY=여기에_액세스키_입력
COUPANG_PARTNERS_SECRET_KEY=여기에_시크릿키_입력

# Coupang Seller API Keys
COUPANG_VENDOR_ID=여기에_벤더ID_입력
COUPANG_SELLER_ACCESS_KEY=여기에_셀러_액세스키_입력
COUPANG_SELLER_SECRET_KEY=여기에_셀러_시크릿키_입력

# Coupang Browser Cookie (for scraping)
COUPANG_COOKIE=

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=여기에_수파베이스_서비스키_입력

# Supabase 브라우저(Auth)용 - 회원가입/로그인에 필수
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=여기에_수파베이스_anon_public_key_입력

# 관리자 이메일 (이 이메일로 가입한 사용자만 /admin 접근 가능)
ADMIN_EMAIL=admin@example.com
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

# 1688 Cookie (optional)
1688_COOKIE=
